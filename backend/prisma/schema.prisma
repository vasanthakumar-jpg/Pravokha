generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEALER
  USER
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  password             String
  name                 String?
  phone                String?
  address              String?
  avatarUrl            String?
  bio                  String?
  dateOfBirth          DateTime?
  role                 Role     @default(USER)
  status               String   @default("active")
  verificationStatus   String   @default("unverified")
  verificationComments String?

  // Dealer / Seller Info
  storeName           String?
  storeDescription    String?
  storeLogoUrl        String?
  storeBannerUrl      String?
  gst                 String?
  pan                 String?
  bankAccount         String?
  ifsc                String?
  beneficiaryName     String?
  vacationMode        Boolean  @default(false)
  autoConfirm         Boolean  @default(true)
  returnPolicy        String?
  metaTitle           String?
  metaDescription     String?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  products             Product[]
  orders               Order[]   @relation("UserOrders")
  orderItems           OrderItem[] @relation("SellerOrderItems")
  notifications        Notification[]
  tickets              SupportTicket[]
  addresses            Address[]
  paymentMethods       PaymentMethod[]
  preferences          UserPreference?
  auditLogs            AuditLog[]
  ticketMessages       TicketMessage[]
  supportConversations SupportConversation[]
  supportMessages      SupportMessage[]
  wishlist             Wishlist[]
  productReviews       ProductReview[]
  adminNotificationSettings AdminNotificationSetting?
  productUpdateRequests ProductUpdateRequest[] @relation("SellerUpdateRequests")
  payouts              Payout[]
  shippedOrders        Order[]   @relation("SellerShippedOrders")

  @@map("users")
}

model Address {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String   // Home, Work, etc.
  fullName      String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  pincode       String
  isDefault     Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("addresses")
}

model Category {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  description String?
  imageUrl    String?
  status      String        @default("active")
  displayOrder Int          @default(0)
  createdAt   DateTime      @default(now())
  
  subcategories Subcategory[]
  products      Product[]

  @@map("categories")
}

model Subcategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  status      String    @default("active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt   DateTime  @default(now())
  
  products    Product[]

  @@map("subcategories")
}

model Product {
  id            String      @id @default(uuid())
  title         String
  slug          String      @unique
  description   String
  price         Float
  discountPrice Float?
  stock         Int         @default(0)
  published     Boolean     @default(false)
  isFeatured    Boolean     @default(false)
  isNew         Boolean     @default(false)
  rating        Float       @default(0.0)
  reviews       Int         @default(0)
  sku           String?     @unique
  isVerified    Boolean     @default(false)
  
  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id])
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
  
  dealerId      String
  dealer        User        @relation(fields: [dealerId], references: [id])
  
  updateRequests ProductUpdateRequest[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  variants      ProductVariant[]
  orderItems    OrderItem[]
  wishlist      Wishlist[]
  productReviews ProductReview[]

  @@map("products")
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName   String?
  colorHex    String?
  images      Json?    // Array of image URLs
  
  sizes       ProductSize[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("product_variants")
}

model ProductSize {
  id          String         @id @default(uuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  size        String
  stock       Int            @default(0)
  
  @@map("product_sizes")
}

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique
  total         Float
  status        OrderStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?
  stripeIntentId String?    @unique
  
  // Shipping details
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  shippingCity    String
  shippingPincode String
  
  userId        String?
  user          User?       @relation("UserOrders", fields: [userId], references: [id])
  
  items         OrderItem[]
  
  // Operational fields for 10/10 flow
  trackingNumber    String?   @map("tracking_number")
  trackingCarrier   String?   @map("tracking_carrier")
  shippedAt         DateTime? @map("shipped_at")
  deliveredAt       DateTime? @map("delivered_at")
  version           Int       @default(0)
  packingNotes      String?   @map("packing_notes") @db.Text
  shippedBySellerId String?   @map("shipped_by_seller_id")
  shippedBySeller   User?     @relation("SellerShippedOrders", fields: [shippedBySellerId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?   @map("deleted_at")
  trackingUpdates Json?     @map("tracking_updates")

  @@map("orders")
}

model Payout {
  id              String       @id @default(uuid())
  sellerId        String       @map("seller_id")
  seller          User         @relation(fields: [sellerId], references: [id])
  amount          Float
  status          PayoutStatus @default(PENDING)
  periodStart     DateTime     @map("period_start")
  periodEnd       DateTime     @map("period_end")
  transactionId   String?      @map("transaction_id")
  rejectionReason String?      @map("rejection_reason") @db.Text
  
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("payouts")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  // Multi-vendor tracking: which seller owns this order item
  sellerId  String  @map("seller_id")
  seller    User    @relation("SellerOrderItems", fields: [sellerId], references: [id])
  
  title     String
  price     Float
  variantId String? @map("variant_id")
  color     String?
  size      String?
  quantity  Int
  
  @@index([sellerId])
  @@map("order_items")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // order, info, alert
  isRead    Boolean  @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model SupportTicket {
  id           String   @id @default(uuid())
  ticketNumber String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  type         String
  subject      String
  description  String   @db.Text
  priority           String   @default("medium")
  status             String   @default("open")
  isSuspendedSeller  Boolean  @default(false) @map("suspended_seller")
  isHighPriority     Boolean  @default(false) @map("is_high_priority")
  evidenceUrls       Json?    // Array of strings
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  messages     TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id          String        @id @default(uuid())
  ticketId    String        @map("ticket_id")
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String        @map("sender_id")
  sender      User          @relation(fields: [senderId], references: [id])
  message     String        @db.Text
  isRead      Boolean       @default(false) @map("is_read")
  isInternal  Boolean       @default(false) @map("is_internal")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("ticket_messages")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?  @map("actor_id")
  actor       User?    @relation(fields: [actorId], references: [id])
  targetId    String?  @map("target_id")
  targetType  String   @map("target_type")
  actionType  String   @map("action_type")
  severity    String?  @default("info")
  description String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model PaymentMethod {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardLast4      String
  cardBrand      String
  cardExpMonth   Int
  cardExpYear    Int
  cardHolderName String
  isDefault      Boolean  @default(false)
  type           String   @default("card")
  label          String   @default("Personal")
  details        Json?    // Extra gateway info
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("payment_methods")
}

model UserPreference {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications Boolean  @default(true)
  orderUpdates       Boolean  @default(true)
  marketingEmails    Boolean  @default(false)
  smsNotifications   Boolean  @default(false)
  theme              String   @default("system")
  language           String   @default("en")
  currency           String   @default("INR")
  twoFactorAuth      Boolean  @default(false)
  
  updatedAt          DateTime @updatedAt

  @@map("user_preferences")
}

model SupportConversation {
  id            String   @id @default(uuid())
  subject       String
  status        String   @default("open")
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")
  messages      SupportMessage[]

  @@map("support_conversations")
}

model SupportMessage {
  id             String              @id @default(uuid())
  conversationId String              @map("conversation_id")
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String              @map("user_id")
  user           User                @relation(fields: [userId], references: [id])
  message        String              @db.Text
  isAdmin        Boolean             @default(false) @map("is_admin")
  createdAt      DateTime            @default(now()) @map("created_at")

  @@map("support_messages")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@map("wishlist")
}

model ProductUpdateRequest {
  id               String   @id @default(uuid())
  productId        String   @map("product_id")
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sellerId         String   @map("seller_id")
  seller           User     @relation("SellerUpdateRequests", fields: [sellerId], references: [id])
  requestedChanges Json     @map("requested_changes")
  status           String   @default("pending") // pending, approved, rejected
  adminNotes       String?  @map("admin_notes") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("product_update_requests")
}

model SiteSetting {
  id                      String   @id @default("primary")
  storeName               String   @default("Pravokha") @map("store_name")
  storeUrl                String   @default("https://pravokha.com") @map("store_url")
  maintenanceMode         Boolean  @default(false) @map("maintenance_mode")
  autoConfirmOrders       Boolean  @default(true) @map("auto_confirm_orders")
  logoUrl                 String?  @map("logo_url")
  bannerUrl               String?  @map("banner_url")
  currency                String   @default("INR")
  timezone                String   @default("IST")
  analyticsEnabled        Boolean  @default(true) @map("analytics_enabled")
  aiInsightsEnabled       Boolean  @default(false) @map("ai_insights_enabled")
  payoutAutomationEnabled Boolean  @default(true) @map("payout_automation_enabled")
  sessionTrackingEnabled  Boolean  @default(true) @map("session_tracking_enabled")
  dataAnonymizationEnabled Boolean @default(false) @map("data_anonymization_enabled")
  publicIndexingEnabled   Boolean  @default(false) @map("public_indexing_enabled")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model AdminNotificationSetting {
  id                   String   @id @default(uuid())
  adminId              String   @unique @map("admin_id")
  admin                User     @relation(fields: [adminId], references: [id])
  governanceAlerts     Boolean  @default(true) @map("governance_alerts")
  revenueTelemetry     Boolean  @default(true) @map("revenue_telemetry")
  inventoryCriticality Boolean  @default(false) @map("inventory_criticality")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("admin_notification_settings")
}

model NewsletterSubscription {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscriptions")
}

model ComboOffer {
  id                 String    @id @default(uuid())
  title              String
  description        String?   @db.Text
  productIds        Json?     @map("product_ids") // Array of string product slugs/IDs
  originalPrice     Float?    @map("original_price")
  comboPrice        Float     @map("combo_price")
  discountPercentage Int?     @map("discount_percentage")
  active             Boolean   @default(true)
  imageUrl           String?   @map("image_url")
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("combo_offers")
}

model ProductReview {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Float
  title     String?
  comment   String?  @db.Text
  images    Json?    // Array of image URLs
  status    String   @default("pending") // pending, approved, rejected
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_reviews")
}

model MigrationAudit {
  id          String   @id @default(uuid())
  entityType  String   // e.g., 'Subcategory'
  entityId    String
  oldData     Json
  newData     Json
  migrationId String   // identifier for the migration run
  createdAt   DateTime @default(now())

  @@map("migration_audit")
}
