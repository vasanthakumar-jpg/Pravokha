generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// RBAC: User Role Enumeration
// Defines the 4 core roles in the marketplace platform
enum Role {
  SUPER_ADMIN  // Platform owner (full access)
  ADMIN        // Platform staff (permission-based access)
  SELLER       // Marketplace vendor (owns products/store)
  CUSTOMER     // End user (buyer)
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  password              String?
  name                  String
  role                  Role                   @default(CUSTOMER)
  googleId              String?                @unique @map("google_id")
  avatarUrl             String?                @map("avatar_url")
  phoneNumber           String?                @map("phone_number")
  dateOfBirth           DateTime?              @map("date_of_birth")
  bio                   String?                @db.LongText
  status                String                 @default("active")
  suspendedBy           String?                @map("suspended_by")
  suspendedAt           DateTime?              @map("suspended_at")
  suspensionReason      String?                @map("suspension_reason")
  suspensionExpiresAt   DateTime?              @map("suspension_expires_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  verificationStatus    String                 @default("unverified") @map("verification_status")
  addresses             Address[]
  adminPermission       AdminPermission?
  auditLogs             AuditLog[]             @relation("PerformedActions")
  notifications         Notification[]
  orders                Order[]                @relation("CustomerOrders")
  paymentMethods        PaymentMethod[]
  payouts               Payout[]
  reviews               ProductReview[]
  productUpdateRequests ProductUpdateRequest[] @relation("SellerRequests")
  supportConversations  SupportConversation[]
  supportMessages       SupportMessage[]
  supportTickets        SupportTicket[]
  ticketMessages        TicketMessage[]        @relation("TicketMessages")
  preferences           UserPreference?
  vendor                Vendor?
  wishlist              Wishlist[]
  returnRequests        ReturnRequest[]        @relation("CustomerReturns")

  @@map("users")
}

model Vendor {
  id                String    @id @default(uuid())
  ownerId           String    @unique @map("owner_id")
  storeName         String    @unique @map("store_name")
  slug              String    @unique
  description       String?   @db.LongText
  logoUrl           String?   @map("logo_url")
  bannerUrl         String?   @map("banner_url")
  gstNumber         String?   @map("gst_number")
  panNumber         String?   @map("pan_number")
  businessAddress   String?   @map("business_address") @db.LongText
  beneficiaryName   String?   @map("beneficiary_name")
  autoConfirm       Boolean   @default(false) @map("auto_confirm")
  returnPolicy      String?   @map("return_policy") @db.LongText
  bankAccountName   String?   @map("bank_account_name")
  bankAccountNumber String?   @map("bank_account_number")
  bankIfscCode      String?   @map("bank_ifsc_code")
  bankName          String?   @map("bank_name")
  status            String    @default("PENDING")
  commissionRate    Float     @default(10) @map("commission_rate")
  supportEmail      String?   @map("support_email")
  supportPhone      String?   @map("support_phone")
  payoutSettings    String?   @map("payout_settings") @db.LongText
  rating            Float     @default(0)
  reviewCount       Int       @default(0) @map("review_count")
  totalSales        Float     @default(0) @map("total_sales")
  totalOrders       Int       @default(0) @map("total_orders")
  verifiedAt           DateTime? @map("verified_at")
  pickupPincode        String?   @map("pickup_pincode")
  warehouseCity        String?   @map("warehouse_city")
  warehouseState       String?   @map("warehouse_state")
  customShippingEnabled Boolean   @default(false) @map("custom_shipping_enabled")
  approvedAt        DateTime? @map("approved_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  metaDescription   String?   @map("meta_description") @db.LongText
  metaTitle         String?   @map("meta_title")
  vacationMode      Boolean   @default(false) @map("vacation_mode")
  orders            Order[]   @relation("VendorOrders")
  payouts           Payout[]  @relation("VendorPayouts")
  products          Product[]
  stockAlerts       StockAlert[]
  owner             User      @relation(fields: [ownerId], references: [id])

  @@map("vendors")
}

model AdminPermission {
  id                  String   @id @default(uuid())
  adminId             String   @unique @map("admin_id")
  canManagePlatform   Boolean  @default(false)
  canManageVendors    Boolean  @default(false)
  canManageUsers      Boolean  @default(false)
  canManageFinancials Boolean  @default(false)
  canAccessAuditLogs  Boolean  @default(false)
  canApproveProducts  Boolean  @default(false)
  canEditAnyProduct   Boolean  @default(false)
  canDeleteAnyProduct Boolean  @default(false)
  canManageCategories Boolean  @default(false)
  canSuspendUsers     Boolean  @default(false)
  canVerifyVendors    Boolean  @default(false)
  canChangeUserRoles  Boolean  @default(false)
  canViewAllOrders    Boolean  @default(false)
  canCancelAnyOrder   Boolean  @default(false)
  canIssueRefunds     Boolean  @default(false)
  canApprovePayouts   Boolean  @default(false)
  canViewFinancials   Boolean  @default(false)
  canModifyCommission Boolean  @default(false)
  canManageAdmins     Boolean  @default(false)
  canChangeSettings   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  admin               User     @relation(fields: [adminId], references: [id])

  @@map("admin_permissions")
}

model Address {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String
  phoneNumber  String   @map("phone_number")
  addressLine1 String   @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String
  state        String
  pincode      String
  isDefault    Boolean  @default(false) @map("is_default")
  type         String   @default("HOME")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "addresses_user_id_fkey")
  @@map("addresses")
}

model Category {
  id            String     @id @default(uuid())
  name          String
  slug          String     @unique
  parentId      String?    @map("parent_id")
  image         String?    @map("image_url")
  description   String?    @db.LongText
  status        String     @default("active")
  displayOrder  Int        @default(0) @map("display_order")
  commissionRate Float     @default(10) @map("commission_rate")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subcategories Category[] @relation("CategoryHierarchy")
  products      Product[]

  @@index([parentId], map: "categories_parent_id_fkey")
  @@map("categories")
}

model Product {
  id                    String                 @id @default(uuid())
  title                 String
  slug                  String                 @unique
  description           String                 @db.LongText
  price                 Float
  compareAtPrice        Float?                 @map("compare_at_price")
  stock                 Int                    @default(0)
  sku                   String?                @unique
  categoryId            String                 @map("category_id")
  vendorId              String                 @map("vendor_id")
  status                String                 @default("DRAFT")
  tags                  String?
  rating                Float                  @default(0)
  reviewCount           Int                    @default(0) @map("review_count")
  isVerified            Boolean                @default(false) @map("is_verified")
  isFeatured            Boolean                @default(false) @map("is_featured")
  isBlocked             Boolean                @default(false) @map("is_blocked")
  adminNotes            String?                @map("admin_notes") @db.LongText
  commissionRate        Float?                 @map("commission_rate")
  verifiedBy            String?                @map("verified_by")
  verifiedAt            DateTime?              @map("verified_at")
  blockedReason         String?                @map("blocked_reason")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  deletedAt             DateTime?              @map("deleted_at")
  hsnCode               String?                @map("hsn_code")
  gstRate               Float                  @default(18) @map("gst_rate")
  taxInclusive          Boolean                @default(false) @map("tax_inclusive")
  lowStockThreshold     Int                    @default(10) @map("low_stock_threshold")
  lastStockAlert        DateTime?              @map("last_stock_alert")
  weight                Float                  @default(0.5)
  length                Float                  @default(20)
  width                 Float                  @default(15)
  height                Float                  @default(5)
  orderItems            OrderItem[]
  images                ProductImage[]
  reviews               ProductReview[]
  productUpdateRequests ProductUpdateRequest[]
  variants              ProductVariant[]
  category              Category               @relation(fields: [categoryId], references: [id])
  vendor                Vendor                 @relation(fields: [vendorId], references: [id])
  wishlist              Wishlist[]
  stockAlerts           StockAlert[]

  @@index([categoryId], map: "products_category_id_fkey")
  @@index([vendorId], map: "products_vendor_id_fkey")
  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  url       String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "product_images_product_id_fkey")
  @@map("product_images")
}

model ProductUpdateRequest {
  id               String   @id @default(uuid())
  productId        String   @map("product_id")
  sellerId         String   @map("seller_id")
  requestedChanges String   @map("requested_changes") @db.LongText
  status           String   @default("pending")
  adminNotes       String?  @map("admin_notes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  product          Product  @relation(fields: [productId], references: [id])
  seller           User     @relation("SellerRequests", fields: [sellerId], references: [id])

  @@index([productId], map: "product_update_requests_product_id_fkey")
  @@index([sellerId], map: "product_update_requests_seller_id_fkey")
  @@map("product_update_requests")
}

model ProductVariant {
  id        String        @id @default(uuid())
  productId String        @map("product_id")
  name      String
  sku       String?       @unique
  price     Float?
  stock     Int           @default(0)
  colorName String?       @map("color_name")
  colorHex  String?       @map("color_hex")
  images    String?       @db.LongText
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sizes     ProductSize[]
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "product_variants_product_id_fkey")
  @@map("product_variants")
}

model ProductSize {
  id        String         @id @default(uuid())
  variantId String
  size      String
  stock     Int            @default(0)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId], map: "product_sizes_variantId_fkey")
  @@map("product_sizes")
}

model WebhookEvent {
  id              String    @id @default(uuid())
  provider        String?
  providerEventId String?    @unique @map("provider_event_id")
  eventType     String    @map("event_type")
  payload       String    @db.LongText
  processed     Boolean   @default(false)
  processedAt   DateTime? @map("processed_at")
  retryCount    Int       @default(0) @map("retry_count")
  errorMessage  String?   @map("error_message") @db.LongText
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([providerEventId])
  @@index([processed])
  @@index([eventType])
  @@map("webhook_events")
}

model Order {
  id                   String               @id @default(uuid())
  orderNumber          String               @unique @map("order_number")
  customerId           String?              @map("customer_id")
  vendorId             String               @map("vendor_id")
  totalAmount          Float                @map("total_amount")
  platformFee          Float                @default(0) @map("platform_fee")
  vendorEarnings       Float                @default(0) @map("vendor_earnings")
  status               OrderStatus          @default(PENDING)
  paymentStatus        PaymentStatus        @default(UNPAID)
  paymentMethod        String               @map("payment_method")
  customerName         String?              @map("customer_name")
  customerEmail        String?              @map("customer_email")
  customerPhone        String?              @map("customer_phone")
  refundedAmount       Float?               @map("refunded_amount")
  refundReason         String?              @map("refund_reason")
  refundedAt           DateTime?            @map("refunded_at")
  paidAt               DateTime?            @map("paid_at")
  shippingAddress      String               @map("shipping_address") @db.LongText
  trackingNumber       String?              @map("tracking_number")
  trackingCarrier      String?              @map("tracking_carrier")
  shippedAt            DateTime?            @map("shipped_at")
  deliveredAt          DateTime?            @map("delivered_at")
  deliveryOtp          String?              @map("delivery_otp")
  otpExpiresAt         DateTime?            @map("otp_expires_at")
  notes                String?              @db.LongText
  version              Int                  @default(1)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?            @map("deleted_at")
  paymentFailureReason PaymentFailureReason @default(NONE) @map("payment_failure_reason")
  shippingFee          Float                @default(0) @map("shipping_fee")
  taxAmount            Float                @default(0) @map("tax_amount")
  cgst                 Float                @default(0)
  sgst                 Float                @default(0)
  igst                 Float                @default(0)
  gstAmount            Float                @default(0) @map("gst_amount")
  buyerGstin           String?              @map("buyer_gstin")
  paymentIntentId      String?              @map("payment_intent_id")
  chargeableWeight     Float?               @map("chargeable_weight")
  appliedZone          String?              @map("applied_zone")
  slabCount            Int?                 @map("slab_count")
  codFee               Float?               @map("cod_fee")
  remoteSurcharge      Float?               @map("remote_surcharge")
  shippingBreakdownJson String?             @db.LongText @map("shipping_breakdown_json")
  platformShippingRevenue Float?            @map("platform_shipping_revenue")
  estimatedCourierCost   Float?             @map("estimated_courier_cost")
  shippingRateVersion    String?            @map("shipping_rate_version")
  items                OrderItem[]
  statusHistory        OrderStatusHistory[]
  paymentTransactions  PaymentTransaction[]
  returnRequests       ReturnRequest[]
  shipments            Shipment[]
  customer             User?                @relation("CustomerOrders", fields: [customerId], references: [id])
  vendor               Vendor               @relation("VendorOrders", fields: [vendorId], references: [id])

  @@index([customerId], map: "orders_customer_id_fkey")
  @@index([vendorId], map: "orders_vendor_id_fkey")
  @@map("orders")
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  productId       String
  priceAtPurchase Float   @map("price_at_purchase")
  quantity        Int
  subtotal        Float
  variantId       String? @map("variant_id")
  color           String?
  size            String?
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product @relation(fields: [productId], references: [id])

  @@index([orderId], map: "order_items_orderId_fkey")
  @@index([productId], map: "order_items_productId_fkey")
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  status    OrderStatus
  notes     String?     @db.LongText
  createdAt DateTime    @default(now()) @map("created_at")
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "order_status_history_order_id_fkey")
  @@map("order_status_history")
}

model Payout {
  id              String       @id @default(uuid())
  vendorId        String       @map("vendor_id")
  userId          String?      @map("user_id")
  amount          Float
  status          PayoutStatus @default(PENDING)
  transactionId   String?      @map("transaction_id")
  paidAt          DateTime?    @map("paid_at")
  rejectionReason String?      @map("rejection_reason")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  user            User?        @relation(fields: [userId], references: [id])
  vendor          Vendor       @relation("VendorPayouts", fields: [vendorId], references: [id])

  @@index([userId], map: "payouts_user_id_fkey")
  @@index([vendorId], map: "payouts_vendor_id_fkey")
  @@map("payouts")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  link      String?
  title     String
  message   String
  metadata  String?  @db.LongText
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "notifications_userId_fkey")
  @@map("notifications")
}

model SupportTicket {
  id                String          @id @default(uuid())
  ticketNumber      String          @unique
  userId            String
  type              String
  subject           String
  description       String          @db.LongText
  priority          String          @default("medium")
  status            String          @default("open")
  isSuspendedSeller Boolean         @default(false) @map("is_suspended_seller")
  evidenceUrls      String?         @map("evidence_urls") @db.LongText
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  user              User            @relation(fields: [userId], references: [id])
  messages          TicketMessage[]

  @@index([userId], map: "support_tickets_userId_fkey")
  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(uuid())
  ticketId   String        @map("ticket_id")
  senderId   String        @map("sender_id")
  message    String        @db.LongText
  isRead     Boolean       @default(false)
  isInternal Boolean       @default(false) @map("is_internal")
  createdAt  DateTime      @default(now()) @map("created_at")
  sender     User          @relation("TicketMessages", fields: [senderId], references: [id])
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([senderId], map: "ticket_messages_sender_id_fkey")
  @@index([ticketId], map: "ticket_messages_ticket_id_fkey")
  @@map("ticket_messages")
}

model AuditLog {
  id             String   @id @default(uuid())
  performedBy    String?  @map("performed_by")
  performerRole  Role     @default(CUSTOMER) @map("performer_role")
  performerEmail String?  @map("performer_email")
  action         String
  entity         String
  entityId       String
  changes        String?  @db.LongText
  reason         String?
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now())
  user           User?    @relation("PerformedActions", fields: [performedBy], references: [id])

  @@index([performedBy], map: "audit_logs_performed_by_fkey")
  @@map("audit_logs")
}

model PaymentMethod {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  type           String   @default("card")
  label          String?
  cardLast4      String?  @map("card_last_4")
  cardBrand      String?  @map("card_brand")
  cardExpMonth   Int?     @map("card_exp_month")
  cardExpYear    Int?     @map("card_exp_year")
  cardHolderName String?  @map("card_holder_name")
  isDefault      Boolean  @default(false) @map("is_default")
  details        String?  @db.LongText
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "payment_methods_user_id_fkey")
  @@map("payment_methods")
}

model UserPreference {
  id                 String   @id @default(uuid())
  userId             String   @unique
  emailNotifications Boolean  @default(true)
  orderUpdates       Boolean  @default(true) @map("order_updates")
  marketingEmails    Boolean  @default(false) @map("marketing_emails")
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model SupportConversation {
  id            String           @id @default(uuid())
  subject       String
  status        String           @default("open")
  userId        String           @map("user_id")
  lastMessageAt DateTime         @default(now()) @map("last_message_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  user          User             @relation(fields: [userId], references: [id])
  messages      SupportMessage[]

  @@index([userId], map: "support_conversations_user_id_fkey")
  @@map("support_conversations")
}

model SupportMessage {
  id             String              @id @default(uuid())
  conversationId String              @map("conversation_id")
  userId         String              @map("user_id")
  message        String              @db.LongText
  isAdmin        Boolean             @default(false)
  createdAt      DateTime            @default(now()) @map("created_at")
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id])

  @@index([conversationId], map: "support_messages_conversation_id_fkey")
  @@index([userId], map: "support_messages_user_id_fkey")
  @@map("support_messages")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId], map: "wishlist_product_id_fkey")
  @@map("wishlist")
}

model ProductReview {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  userId    String   @map("user_id")
  rating    Float
  title     String?
  comment   String?  @db.LongText
  images    String?  @db.LongText
  metadata  String?  @db.LongText // Stored as JSON for review categories
  status    String   @default("published")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId], map: "product_reviews_product_id_fkey")
  @@index([userId], map: "product_reviews_user_id_fkey")
  @@map("product_reviews")
}

model NewsletterSubscription {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscriptions")
}

model ComboOffer {
  id                 String    @id @default(uuid())
  title              String
  description        String?   @db.LongText
  productIds         String?   @map("product_ids") @db.LongText
  originalPrice      Float?    @map("original_price")
  comboPrice         Float     @map("combo_price")
  discountPercentage Int?      @map("discount_percentage")
  imageUrl           String?   @map("image_url")
  active             Boolean   @default(true)
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@map("combo_offers")
}

model SiteSetting {
  id                   String   @id @default("primary")
  storeName            String   @default("Pravokha") @map("store_name")
  commissionRate       Float    @default(10) @map("commission_rate")
  updatedAt            DateTime @updatedAt @map("updated_at")
  autoConfirmOrders    Boolean  @default(true) @map("auto_confirm_orders")
  bannerUrl            String?  @map("banner_url")
  logoUrl              String?  @map("logo_url")
  maintenanceMode      Boolean  @default(false) @map("maintenance_mode")
  notificationSettings String?  @map("notification_settings") @db.LongText
  storeUrl             String   @default("https://pravokha.com") @map("store_url")
  systemSettings       String?  @map("system_settings") @db.LongText
  defaultShippingFee   Float    @default(99) @map("shipping_fee")
  taxRate              Float    @default(18) @map("tax_rate")
  freeShippingThreshold Float   @default(1999) @map("free_shipping_threshold")

  @@map("site_settings")
}

model PaymentTransaction {
  id                    String            @id @default(uuid())
  orderId               String            @map("order_id")
  razorpayOrderId       String?           @unique @map("razorpay_order_id")
  razorpayPaymentId     String?           @unique @map("razorpay_payment_id")
  razorpaySignature     String?           @map("razorpay_signature")
  amount                Float
  currency              String            @default("INR")
  status                TransactionStatus @default(CREATED)
  paymentMethod         String?           @map("payment_method")
  paymentMethodDetails  String?           @db.LongText @map("payment_method_details")
  errorCode             String?           @map("error_code")
  errorDescription      String?           @map("error_description")
  failureReason         String?           @map("failure_reason")
  refundId              String?           @map("refund_id")
  refundAmount          Float?            @map("refund_amount")
  refundStatus          String?           @map("refund_status")
  metadata              String?           @db.LongText
  attempts              Int               @default(0)
  lastAttemptAt         DateTime?         @map("last_attempt_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  order                 Order             @relation(fields: [orderId], references: [id])

  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
  @@index([orderId])
  @@index([status])
  @@map("payment_transactions")
}

enum TransactionStatus {
  CREATED
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SELLER
  CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PROCESSING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  COMPLETED
  REJECTED
}

enum PaymentFailureReason {
  NONE
  EXPIRED_CARD
  INSUFFICIENT_FUNDS
  AUTHENTICATION_REQUIRED
  DECLINED
  NETWORK_ERROR
  FRAUD_SUSPECTED
  INVALID_CARD
  CARD_NOT_SUPPORTED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model EmailLog {
  id           String      @id @default(uuid())
  recipient    String
  subject      String
  template     String
  status       EmailStatus @default(PENDING)
  sentAt       DateTime?   @map("sent_at")
  errorMessage String?     @map("error_message") @db.LongText
  metadata     String?     @db.LongText
  createdAt    DateTime    @default(now()) @map("created_at")

  @@map("email_logs")
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKUP_SCHEDULED
  PICKED_UP
  REFUNDED
}

model ReturnRequest {
  id              String       @id @default(uuid())
  orderId         String       @map("order_id")
  customerId      String       @map("customer_id")
  reason          String       @db.LongText
  status          ReturnStatus @default(REQUESTED)
  images          String?      @db.LongText
  refundAmount    Float        @map("refund_amount")
  approvedBy      String?      @map("approved_by")
  approvedAt      DateTime?    @map("approved_at")
  rejectedReason  String?      @map("rejected_reason") @db.LongText
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  order           Order        @relation(fields: [orderId], references: [id])
  customer        User         @relation("CustomerReturns", fields: [customerId], references: [id])

  @@map("return_requests")
}

enum ShipmentStatus {
  PENDING
  PICKUP_SCHEDULED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  CANCELLED
}

model Shipment {
  id                 String         @id @default(uuid())
  orderId            String         @map("order_id")
  shiprocketOrderId  Int?           @map("shiprocket_order_id")
  awb                String?        // Airway Bill Number
  courierName        String?        @map("courier_name")
  trackingUrl        String?        @map("tracking_url")
  status             ShipmentStatus @default(PENDING)
  pickupScheduled    DateTime?      @map("pickup_scheduled")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  order              Order          @relation(fields: [orderId], references: [id])

  @@map("shipments")
}

model StockAlert {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  vendorId     String   @map("vendor_id")
  currentStock Int      @map("current_stock")
  threshold    Int
  notified     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  product      Product  @relation(fields: [productId], references: [id])
  vendor       Vendor   @relation(fields: [vendorId], references: [id])

  @@map("stock_alerts")
}

model ShippingZone {
  id                   String   @id @default(uuid())
  zoneName             String   @map("zone_name")
  baseSlabPrice        Float    @map("base_slab_price")
  additionalSlabPrice  Float    @map("additional_slab_price")
  codFee               Float    @default(50) @map("cod_fee")
  remoteSurcharge      Float    @default(100) @map("remote_surcharge")
  expressMultiplier    Float    @default(1.5) @map("express_multiplier")
  minDays              Int      @default(3) @map("min_days")
  maxDays              Int      @default(7) @map("max_days")
  rateVersion          String   @default("v1") @map("rate_version")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("shipping_zones")
}

model PincodeZoneMapping {
  pincode   String  @id
  zoneId    String  @map("zone_id")
  isRemote  Boolean @default(false) @map("is_remote")

  @@map("pincode_zone_mappings")
}

model ShippingAuditLog {
  id               String   @id @default(uuid())
  timestamp        DateTime @default(now())
  cartId           String?  @map("cart_id")
  calculatedWeight Float    @map("calculated_weight")
  appliedZone      String   @map("applied_zone")
  finalAmount      Float    @map("final_amount")
  metadata         String?  @db.LongText

  @@map("shipping_audit_logs")
}

